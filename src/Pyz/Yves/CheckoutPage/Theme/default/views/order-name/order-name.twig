{% extends template('page-layout-checkout', 'CheckoutPage') %}

{% define data = {
    stepNumder: 2,
    backUrl: _view.previousStepUrl,
    forms: {
        orderName: _view.orderNameForm
    },

    title: 'checkout.step.order-name.title' | trans
} %}

{% block content %}
    {% embed molecule('form') with {
        class: 'box',
        data: {
            form: data.forms.orderName,
            options: {
                attr: {
                    id: 'order-name-form'
                }
            },
            submit: {
                isSingleClickEnforcerEnabled: false,
                enable: true,
                text: 'checkout.step.shipment' | trans
            },
            cancel: {
                enable: true,
                url: data.backUrl,
                text: 'general.back.button' | trans
            }
        }
    } only %}
    {% endembed %}
{% endblock %}
